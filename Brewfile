# Install with: brew bundle --file=~/dev/dotfiles/Brewfile
# Regenerate a snapshot of everything installed: brew bundle dump --force

#####################################################
# Shell
#####################################################
brew "powerlevel10k"            # zsh prompt theme
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"

#####################################################
# Core CLI
#####################################################
brew "gh"                       # GitHub CLI (also used for git auth token)
brew "jq"
brew "tree"
brew "watch"
brew "httpie"                   # friendly curl replacement
brew "uv"                       # Python package manager
